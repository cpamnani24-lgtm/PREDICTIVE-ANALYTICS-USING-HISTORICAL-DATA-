import pandas as pd
from sklearn.linear_model import LinearRegression
import matplotlib.pyplot as plt

# Sample Historical Data
data = {
    "Month": [1,2,3,4,5,6,7,8],
    "Sales": [120,150,180,220,260,300,340,390]
}

df = pd.DataFrame(data)

X = df[["Month"]]
y = df["Sales"]

model = LinearRegression()
model.fit(X, y)

future = pd.DataFrame({"Month":[9,10,11,12]})
prediction = model.predict(future)

print("Future Predictions:")
for m, p in zip(future["Month"], prediction):
    print(f"Month {m}: {round(p)}")

plt.plot(df["Month"], df["Sales"], marker="o", label="Historical Sales")
plt.plot(future["Month"], prediction, marker="o", label="Predicted Sales")
plt.xlabel("Month")
plt.ylabel("Sales")
plt.title("Predictive Analytics Using Historical Data")
plt.legend()
plt.show()
